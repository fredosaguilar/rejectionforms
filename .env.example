# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=replace_with_long_random_secret

# ── Database (Railway Postgres) ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/eoforms

# ── Formstack Sign ────────────────────────────────────────────────────────────
# OAuth Access Token — Formstack Sign → Settings → API → OAuth Access Token
FORMSTACK_ACCESS_TOKEN=your_formstack_sign_access_token_here

# ── Agency ────────────────────────────────────────────────────────────────────
AGENCY_NAME=Quincy Alliance Insurance LLC DBA Columbia Basin Insurance
AGENCY_EMAIL=your-agency-email@columbibasinins.com
